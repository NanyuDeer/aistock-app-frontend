# API 基础地址（App 运行时使用，H5 走 vite 代理用相对路径 /api）
VITE_API_BASE_URL=/api
# WebSocket 地址（Node.js 服务）
VITE_WS_BASE_URL=ws://localhost:3000/ws
# Agent Python 后端 WebSocket 地址（后端路由前缀 /api/agent + /ws/chat）
VITE_AGENT_WS_BASE=ws://localhost:8080/api/agent/ws

# Vite 开发代理目标（仅 dev server proxy 使用，不影响构建产物）
VITE_PROXY_API_TARGET=http://localhost:3000
VITE_PROXY_AGENT_TARGET=http://localhost:8080
VITE_PROXY_WS_TARGET=ws://localhost:3000

# 微信 OAuth（App 端 uni.login 使用，manifest.json 编译时同步）
# 请替换为你的真实 AppID 和 AppSecret，切勿提交真实密钥到公开仓库
VITE_WX_APPID=your_wx_appid
VITE_WX_APPSECRET=your_wx_appsecret
