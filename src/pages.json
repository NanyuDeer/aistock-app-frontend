{
  "easyCom": {
    "autoscan": true,
    "custom": {
      "^wd-(.*)": "wot-design-uni/components/wd-$1/wd-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "早点听",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/stock/detail",
      "style": {
        "navigationBarTitleText": "个股详情"
      }
    },
    {
      "path": "pages/stock/search",
      "style": {
        "navigationBarTitleText": "搜索"
      }
    },
    {
      "path": "pages/favorites/index",
      "style": {
        "navigationBarTitleText": "自选股",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/news/wechat-message",
      "style": {
        "navigationBarTitleText": "资讯"
      }
    },
    {
      "path": "pages/tag/leaders",
      "style": {
        "navigationBarTitleText": "板块龙头"
      }
    },
    {
      "path": "pages/user/login",
      "style": {
        "navigationBarTitleText": "登录"
      }
    },
    {
      "path": "pages/user/profile",
      "style": {
        "navigationBarTitleText": "我的"
      }
    },
    {
      "path": "pages/about/update-logs",
      "style": {
        "navigationBarTitleText": "更新日志"
      }
    }
  ],
  "subPackages": [
    {
      "root": "pages-sub-app",
      "pages": [
        {
          "path": "chat/index",
          "style": {
            "navigationBarTitleText": "AI 投顾",
            "navigationStyle": "custom"
          }
        },
        {
          "path": "briefing/index",
          "style": {
            "navigationBarTitleText": "双人对话播报"
          }
        },
        {
          "path": "event-chain/index",
          "style": {
            "navigationBarTitleText": "事件传导"
          }
        },
        {
          "path": "valuation/index",
          "style": {
            "navigationBarTitleText": "动态估值"
          }
        },
        {
          "path": "portfolio/index",
          "style": {
            "navigationBarTitleText": "持仓陪伴"
          }
        },
        {
          "path": "review/index",
          "style": {
            "navigationBarTitleText": "交易复盘"
          }
        }
      ]
    },
    {
      "root": "pages-sub-mp",
      "pages": [
        {
          "path": "wechat-bot/index",
          "style": {
            "navigationBarTitleText": "微信智能体"
          }
        }
      ]
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "AI Stock",
    "navigationBarBackgroundColor": "#1a1a2e",
    "backgroundColor": "#0f0f1e",
    "backgroundTextStyle": "light"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#007AFF",
    "backgroundColor": "#1a1a2e",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "早点听"
      },
      {
        "pagePath": "pages/favorites/index",
        "text": "自选"
      },
      {
        "pagePath": "pages/user/profile",
        "text": "我的"
      }
    ]
  }
}
